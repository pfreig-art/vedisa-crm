# ============================================================
# VEDISA CRM - Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# En dev puedes dejarlo vacio: los defaults usan SQLite y secret no productivo.
# ============================================================

# ---- Base de datos -----------------------------------------
# Produccion (Postgres compartido, db dedicada):
#   DATABASE_URL=postgresql+asyncpg://vedisa_app:CAMBIAR@localhost:5432/vedisa_crm
# Dev local con SQLite:
#   DATABASE_URL=sqlite+aiosqlite:///./vedisa_dev.db
DATABASE_URL=postgresql+asyncpg://vedisa_app:CAMBIAR@localhost:5432/vedisa_crm

# ---- Auth / JWT --------------------------------------------
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CAMBIAR_POR_VALOR_ALEATORIO_LARGO
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- CORS --------------------------------------------------
# Lista JSON. En intranet HTTP plano basta con localhost.
CORS_ORIGINS=["http://localhost","http://localhost:5173"]

# ---- Runtime -----------------------------------------------
ENVIRONMENT=production
HOST=127.0.0.1
PORT=8081
APP_VERSION=0.3.0

# ---- Proveedores LLM ---------------------------------------
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_FALLBACK_MODEL=claude-3-haiku-20240307

GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-1.5-pro
GEMINI_FALLBACK_MODEL=gemini-1.5-flash

DEEPSEEK_API_KEY=
DEEPSEEK_DEFAULT_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=
LITELLM_DEFAULT_MODEL=

# ---- Router LLM --------------------------------------------
LLM_PRIMARY_PROVIDER=anthropic
LLM_FALLBACK_PROVIDER=openai
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# ---- Observabilidad ----------------------------------------
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4318
LOG_LEVEL=INFO

# ---- Backups (consumidos por deploy/windows/backup.ps1) ----
# PG_USER=vedisa_app
# PGPASSWORD=CAMBIAR
