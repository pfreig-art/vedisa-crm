# ============================================================
# VEDISA CRM - Variables de entorno
# Copia este archivo a .env y rellena los valores reales
# ============================================================

# Base de datos
DATABASE_URL=postgresql+asyncpg://vedisa:password@localhost:5432/vedisa_crm

# Auth JWT
SECRET_KEY=cambia-esto-por-un-secreto-seguro-de-64-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ---- Proveedores LLM ----------------------------------------
# Deja en blanco los proveedores que no uses

OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_FALLBACK_MODEL=claude-3-haiku-20240307

GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-1.5-pro
GEMINI_FALLBACK_MODEL=gemini-1.5-flash

DEEPSEEK_API_KEY=
DEEPSEEK_DEFAULT_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenRouter (gateway multi-modelo)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# LiteLLM (gateway self-hosted)
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=
LITELLM_DEFAULT_MODEL=

# ---- Router LLM ---------------------------------------------
# Proveedor primario: openai | anthropic | gemini | deepseek | openrouter | litellm
LLM_PRIMARY_PROVIDER=anthropic
LLM_FALLBACK_PROVIDER=openai
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# ---- Observabilidad -----------------------------------------
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4318
LOG_LEVEL=INFO
